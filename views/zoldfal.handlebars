{{> layout/hero
        title="Zöldfal"
        text="Látványos, modern zöldfal megoldások tervezése, kivitelezése és
    karbantartása Nyíregyházán és környékén. Jelenleg a LEGO-nál tartunk karban
    zöldfalat."
}}

<section class="section">
  <div class="grid">
      {{> card
              small="Szolgáltatás"
              title="Zöld fal kivitelezés"
      description="Helyszíni felmérés, tervezés, telepítés és igény szerint rendszeres
        karbantartás."
      }}
      {{> card
              small="Előny"
              title="Prémium megjelenés"
              description="Esztétikus, természetközeli látvány irodában, üzletben vagy
        vendégtérben."
      }}
  </div>
</section>

<section class="section">
  <h2>Referencia munkák</h2>
  <p>Kattints a képekre a nagyításhoz — nyilakkal vagy billentyűzettel
    válthatsz.</p>

  <div class="grid glightbox-gallery">
    <div class="imgbox">
      <a
        href="img/zoldfal/zoldfal-01.jpg"
        class="js-lightbox"
        data-index="0"
        data-jpg="img/zoldfal/zoldfal-01.jpg"
        data-webp="img/zoldfal/zoldfal-01.webp"
        title="Zöld fal referencia 1"
      >
        <picture>
          <source
            srcset="img/zoldfal/thumbs/zoldfal-01.webp"
            type="image/webp"
          />
          <img
            src="img/zoldfal/thumbs/zoldfal-01.jpg"
            alt="Zöld fal referencia munka 1 - {{contact.name}} e.v. Nyíregyháza"
            loading="lazy"
            decoding="async"
          />
        </picture>
      </a>
      <div class="imgcap">
        <small>Telepített zöldfal, beltéri megoldás.</small>
      </div>
    </div>

    <div class="imgbox">
      <a
        href="img/zoldfal/zoldfal-02.jpg"
        class="js-lightbox"
        data-index="1"
        data-jpg="img/zoldfal/zoldfal-02.jpg"
        data-webp="img/zoldfal/zoldfal-02.webp"
        title="Zöld fal referencia 2"
      >
        <picture>
          <source
            srcset="img/zoldfal/thumbs/zoldfal-02.webp"
            type="image/webp"
          />
          <img
            src="img/zoldfal/thumbs/zoldfal-02.jpg"
            alt="Zöld fal referencia munka 2 - {{contact.name}} e.v. Nyíregyháza"
            loading="lazy"
            decoding="async"
          />
        </picture>
      </a>
      <div class="imgcap">
        <small>Részletfotó, növény-összeállítás.</small>
      </div>
    </div>
  </div>
</section>
