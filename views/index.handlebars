{{> layout/hero
        title="Minden ami öntözés és kert karbantartás"
        text="Válaszd ki, miben segíthetek — külön oldalon külön referencia képekkel."
}}
<section class="section">
  <div class="grid">
      {{> card
              small="Szolgáltatás"
              title="Öntözőrendszer"
              description="Tervezés, telepítés, javítás, téliesítés/tavaszi indítás."
      }}

      {{> card
              small="Szolgáltatás"
              title="Kertkarbantartás"
              description="Fűnyírás, metszés, kaszálás, általános kertgondozás, tervezés, építés"
      }}

      {{> card
              small="Szolgáltatás"
              title="Zöldfal"
              description="Látványos, modern zöldfal megoldások tervezése, kivitelezés és karbantartás Nyíregyházán és környékén."
      }}

  </div>
</section>

<section id="idopont" class="section">
  <h2>Időpontfoglalás</h2>
  <div class="contact">
    <form action="/idopontfoglalas" method="POST">
      <label for="name">Név:</label><br>
      <input type="text" name="name" required><br><br>

      <label for="email">E-mail:</label><br>
      <input type="email" name="email" required><br><br>

      <label for="phone">Telefonszám:</label><br>
      <input type="text" name="phone" required><br><br>

      <label for="message">Üzenet:</label><br>
      <textarea name="message" rows="4" required></textarea><br><br>

      <button class="button" type="submit">Küldés</button>
    </form>
  </div>
</section>

<section id="kapcsolat" class="section">
  <h2>Kapcsolat</h2>
  <p><b>Név:</b> {{contact.name}}</p>
  <p><b>Telefon:</b>
    {{#each contact.phone_numbers}}
      <a href="tel:{{this}}">{{this}}</a>{{#unless @last}} | {{/unless}}
    {{/each}}
  </p>
  <p><b>E-mail:</b> <a href="mailto:{{contact.email_address}}">{{contact.email_address}}</a></p>
  <p><b>Működési terület:</b> Nyíregyháza és környéke</p>
</section>
